{
  "providers": {
    "aihubmix": {
      "api_key": "${AIHUBMIX_API_KEY:?set AIHUBMIX_API_KEY}"
    }
  },
  "models": {
    "large": {
      "model": "gpt-5.5-free",
      "provider": "aihubmix",
      "reasoning_effort": "medium",
      "max_tokens": 128000
    }
  },
  "recent_models": {
    "large": [
      {
        "model": "gpt-5.5-free",
        "provider": "aihubmix"
      },
      {
        "model": "coding-glm-4.6-free",
