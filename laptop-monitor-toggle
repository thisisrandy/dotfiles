          <width>1920</width>
          <height>1080</height>
          <rate>60.000</rate>
        </mode>
      </monitor>
    </logicalmonitor>
  </configuration>
</monitors>" >~/.config/monitors.xml
  fi
else
  zenity --question --default-cancel --title="" --text="Switch to Join Displays Mode?"
