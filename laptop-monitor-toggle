#!/bin/bash

# Extract only the "Logical monitors" block from the gdctl output
LOGICAL_MONITORS=$(gdctl show | sed -n '/^Logical monitors:/,$p')

# Check if eDP-1 is actively serving as a mapped logical display
if grep -q "eDP-1" <<<"$LOGICAL_MONITORS"; then
  echo "Laptop screen is active. Switching to: External Only Mode"

  # External Only: Omit eDP-1. Shift external displays to fill the canvas from x=0.
  gdctl set --layout-mode logical \
    --logical-monitor --monitor DP-4 --mode 1920x1080@60.000 --x 0 --y 0 --primary \
    --logical-monitor --monitor DP-2 --mode 1920x1080@60.000 --x 1920 --y 0

else
  echo "Laptop screen is disabled. Switching to: Join Displays Mode"

  # Join Displays: Re-insert eDP-1 and slide external screens back to their
  # original offsets.
  gdctl set --layout-mode logical \
    --logical-monitor --monitor eDP-1 --mode 1920x1080@60.150 --x 0 --y 0 \
    --logical-monitor --monitor DP-4 --mode 1920x1080@60.000 --x 1920 --y 0 --primary \
    --logical-monitor --monitor DP-2 --mode 1920x1080@60.000 --x 3840 --y 0
fi
