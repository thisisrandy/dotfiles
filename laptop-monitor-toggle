    gdctl set --layout-mode logical \
      --logical-monitor --monitor $TERTIARY --mode 1920x1080@60.000 --x 0 --y 0 \
      --logical-monitor --monitor $PRIMARY --mode 1920x1080@60.000 --x 1920 --y 0 --primary \
      --logical-monitor --monitor $SECONDARY --mode 1920x1080@60.000 --x 3840 --y 0
